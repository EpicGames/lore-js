{% import "utils.ji" as utils %}

import koffi, { KoffiConfig } from "koffi";

import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';
import { createRequire } from 'node:module';
const require = createRequire(import.meta.url);

{{ utils.enum_imports(symbols, "../types/enums/index.js") }}
{{ utils.enum_ffi_imports(symbols, "../types/enums/ffi.js") }}
