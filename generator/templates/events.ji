Export a map from lore event tag names to LoreEventTag enum values.

    export const TagNameLoreEventTagMap = {
      "progress": LoreEventTag.PROGRESS,
      "error": LoreEventTag.ERROR,
      "complete": LoreEventTag.COMPLETE,
      "metadata": LoreEventTag.METADATA,
      // [...]
    };

#}
export const TagNameLoreEventTagMap: Record<LoreEvent["tagName"], LoreEventTag> = {
  {% for enum_name, enum_values in symbols.enums.items() %}
    {% if enum_name == 'lore_event_tag_t' %}
      {% for value in enum_values %}
        "{{camel_case(value.lower())}}": LoreEventTag.{{value}},
