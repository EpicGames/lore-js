{#

Export event Typescript interfaces and the corresponding Koffi struct definitions.

For instance, for the the struct `lore_auth_url_event_data_t`
    typedef struct lore_auth_url_event_data_t {
        // Authentication URL
        struct lore_string_t url;
    } lore_auth_url_event_data_t;

The result is:

    export interface LoreAuthUrlEventData<LoreContext = string, LoreHash = string, LoreBranchId = string, LoreRepositoryId = string, LoreInstanceId = string, LorePartition = string> {
      url: LoreString;
    }

#}
{% for struct_type, struct_fields in symbols.events.items() %}
  {% if struct_type in array_type_map %}
    {# Auto-generated `_array_t` alias. Element/FFI info lives in generator/registry.py. #}
    {% set arr = array_type_map[struct_type] %}
    export type {{ arr.js_class }}<LoreContext = string, LoreHash = string, LoreBranchId = string, LoreRepositoryId = string, LoreInstanceId = string, LorePartition = string> =
      {% if arr.ptr_field_comments %}
        /** {{ "\n".join(arr.ptr_field_comments) }} */
      {% endif %}
      {{ arr.js_inner_type }}[];
  {% else %}
    export interface {{ pascal_case(struct_type.removesuffix("_t")) }}<LoreContext = string, LoreHash = string, LoreBranchId = string, LoreRepositoryId = string, LoreInstanceId = string, LorePartition = string> {
      {% for field in struct_fields %}
          {% if cToJsTypeMap[field.0] %}
              {% if field.0 == "uint8_t" and field.1 == "data"%}
                {% set field_js_type = "number" %}
            {% else %}
                {% set field_js_type = cToJsTypeMap[field.0] %}
            {% endif %}
          {% elif field.0.endswith("_array_t") %}
              {% set field_js_type = pascal_case(field.0.removesuffix("_t")) + "<LoreContext, LoreHash, LoreBranchId, LoreRepositoryId, LoreInstanceId, LorePartition>" %}
          {% elif field.0.endswith("_t") %}
              {% set field_js_type = pascal_case(field.0.removesuffix("_t")) %}
          {% else %}
              {% set field_js_type = field.0 %}
          {% endif %}
          {% if field_js_type.endswith("EventData")%}
              {% set field_js_type = field_js_type + "<LoreContext, LoreHash, LoreBranchId, LoreRepositoryId, LoreInstanceId, LorePartition>" %}
          {% endif %}
          {% if field.3 %}
            /** {{ "\n".join(field.3) }} */
          {% endif %}
          {% if field.2 != 0 %}
              {{camel_case(field.1)}}: [{{ ([field_js_type] * (field.2 | int)) | join(", ") }}];
          {% else %}
              {{camel_case(field.1)}}: {{ field_js_type }};
          {% endif %}
      {% endfor %}
    }
  {% endif %}
{% endfor %}

{#

Export a type map from LoreEventTag enum values to the corresponding event type definition.

    export type LoreEventTagLoreEventMap<LoreContext = string, LoreHash = string, LoreBranchId = string, LoreRepositoryId = string, LoreInstanceId = string, LorePartition = string> = {
      [LoreEventTag.PROGRESS]: LoreProgressEvent<LoreContext, LoreHash, LoreBranchId, LoreRepositoryId, LoreInstanceId, LorePartition>;
      [LoreEventTag.ERROR]: LoreErrorEvent<LoreContext, LoreHash, LoreBranchId, LoreRepositoryId, LoreInstanceId, LorePartition>;
      [LoreEventTag.COMPLETE]: LoreCompleteEvent<LoreContext, LoreHash, LoreBranchId, LoreRepositoryId, LoreInstanceId, LorePartition>;
      [LoreEventTag.METADATA]: LoreMetadataEvent<LoreContext, LoreHash, LoreBranchId, LoreRepositoryId, LoreInstanceId, LorePartition>;
      // [...]
    };

#}
export type LoreEventTagLoreEventMap<LoreContext = string, LoreHash = string, LoreBranchId = string, LoreRepositoryId = string, LoreInstanceId = string, LorePartition = string> = {
  {% for enum_name, enum_values in symbols.enums.items() %}
    {% if enum_name == 'lore_event_tag_t' %}
      {% for value in enum_values %}
        [LoreEventTag.{{value}}]: Lore{{pascal_case(value.lower())}}Event<LoreContext, LoreHash, LoreBranchId, LoreRepositoryId, LoreInstanceId, LorePartition>;
      {% endfor %}
    {% endif %}
  {% endfor %}
}

