}

{#

Export type LoreEventFFI with tag and a getter for lazy loading the LoreEventData.

    export type LoreEventFFI = 
      | {
          userContext: number;
          tag: LoreEventTag.PROGRESS;
          data: LoreProgressEventData;
          clone: () => LoreProgressEvent;
        }
      | {
          userContext: number;
          tag: LoreEventTag.ERROR;
          data: LoreErrorEventData;
          clone: () => LoreErrorEvent;
        }
      // [...]

#}
export type LoreEventFFI = { userContext: number } & (
  {% for enum_name, enum_values in symbols.enums.items() %}
    {% if enum_name == 'lore_event_tag_t' %}
      {% for value in enum_values %}
        | {
          tag: LoreEventTag.{{value}};
          data: Lore{{pascal_case(value.lower())}}EventData<LoreContextBinary, LoreHashBinary, LoreBranchIdBinary, LoreRepositoryIdBinary>;
          clone: () => Lore{{pascal_case(value.lower())}}Event;
        }
      {% endfor %}
    {% endif %}
  {% endfor %}
)

export type LoreEventFFITyped<T extends LoreEventTag> = Extract<LoreEventFFI, { tag: T }>;

export enum LoreJSStringDecodeMode {
  /** Decode all the event FFI strings into JS strings on initial event access. This is more performant, if you are cloning the whole event, or accessing most of the strings. */
  DEFAULT = 0,
  /**  Lazy decode the individual FFI strings into JS strings when accessing the string. This is more performant, if you you are not going to clone the whole event and not going to access most of the strings. */
  LAZY = 1,
};

{# External JS callback function definition, different from the raw C callback. #}
export declare type LoreEventCallbackFunction = (event: LoreEventFFI) => void;

export declare interface LoreEventCallbackConfig {
  userContext?: number;
  callback: LoreEventCallbackFunction;
  stringDecodeMode?: LoreJSStringDecodeMode;
}

